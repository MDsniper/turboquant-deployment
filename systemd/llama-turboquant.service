[Unit]
Description=llama.cpp server with TurboQuant (Qwen3.6-35B-A3B)
Documentation=https://github.com/TheTom/turboquant_plus
After=network.target

[Service]
Type=simple
# IMPORTANT: Replace <USER> with your actual Linux username
User=<USER>
Group=<USER>
Restart=always
RestartSec=5

WorkingDirectory=/home/<USER>

# CUDA library path for custom llama.cpp build
Environment="LD_LIBRARY_PATH=/home/<USER>/llama-cpp-turboquant/build/bin"
Environment="CUDA_VISIBLE_DEVICES=0"
Environment="HOME=/home/<USER>"

# Main server process
ExecStart=/home/<USER>/llama-cpp-turboquant/build/bin/llama-server \
    -m /home/<USER>/models/Qwen3.6-35B-A3B-UD-Q4_K_M.gguf \
    --alias "Qwen3.6-35B-A3B-TurboQuant" \
    -ngl 99 \
    -c 24576 \
    -fa on \
    --jinja \
    --cache-type-k q8_0 \
    --cache-type-v turbo4 \
    -np 1 \
    --metrics \
    --host 0.0.0.0 \
    --port 8080

# Security hardening (optional — uncomment if desired)
# NoNewPrivileges=true
# ProtectSystem=strict
# ProtectHome=true

[Install]
WantedBy=multi-user.target
