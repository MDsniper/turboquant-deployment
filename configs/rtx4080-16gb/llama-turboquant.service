[Unit]
Description=llama.cpp server with TurboQuant (RTX 4080 16GB config)
Documentation=https://github.com/TheTom/turboquant_plus
After=network.target

[Service]
Type=simple
# IMPORTANT: Replace <USER> with your actual Linux username
User=<USER>
Group=<USER>
Restart=always
RestartSec=5

WorkingDirectory=/home/<USER>

# CUDA library path for custom llama.cpp build
Environment="LD_LIBRARY_PATH=/home/<USER>/llama-cpp-turboquant/build/bin"
Environment="CUDA_VISIBLE_DEVICES=0"
Environment="HOME=/home/<USER>"

# RTX 4080 16GB Configuration
# - Context reduced to 12K to fit in 16GB VRAM
# - Uses Qwen3.6-35B-A3B UD-Q4_K_S (~16GB) or smaller quant
# - Alternative: Qwen2.5-14B Q8_0 (~14GB) for more headroom
# - Adjust model path and context size based on your chosen model

ExecStart=/home/<USER>/llama-cpp-turboquant/build/bin/llama-server \
    -m /home/<USER>/models/MODEL_FOR_16GB.gguf \
    --alias "Qwen-TurboQuant-4080" \
    -ngl 99 \
    -c 12288 \
    -fa on \
    --jinja \
    --cache-type-k q8_0 \
    --cache-type-v turbo4 \
    -np 1 \
    --metrics \
    --host 0.0.0.0 \
    --port 8080

[Install]
WantedBy=multi-user.target
